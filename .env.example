# DeepSeek API key for AI chat
DEEPSEEK_API_KEY=sk-your-key-here

# AI model configuration (optional — defaults to DeepSeek v4 Flash)
# AI_MODEL=deepseek-v4-flash
# AI_BASE_URL=https://api.deepseek.com/v1

# Database (SQLite local — default)
DATABASE_URL=file:./data/life.db

# Turso cloud database (optional — set to use Turso instead of local SQLite)
# TURSO_DATABASE_URL=libsql://your-database.turso.io
# TURSO_AUTH_TOKEN=your-turso-token

# App password for login protection (optional — leave empty to disable)
APP_PASSWORD=demo
