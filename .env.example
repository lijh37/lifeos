# Turso cloud database (备用生产环境必需；主生产/本地用下方 DATABASE_URL 走本地 SQLite)
# Get these from https://turso.tech
TURSO_DATABASE_URL=libsql://your-database.turso.io
TURSO_AUTH_TOKEN=your-turso-token

# Local/CI database (主生产 Docker 与本地开发使用；:memory: 用于单元测试)
# DATABASE_URL=file:./data/life.db

# App password for login protection (optional — leave empty to disable)
APP_PASSWORD=demo

# Vercel Blob storage for file attachments
# Get from Vercel Dashboard → Storage → Blob → Create store
# Or run: npx vercel env add BLOB_READ_WRITE_TOKEN
BLOB_READ_WRITE_TOKEN=your-blob-read-write-token
