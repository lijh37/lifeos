# LifeOS 自托管环境变量模板
# 复制为 .env（或 export 到 shell），docker-compose 会自动读取
# 此文件刻意解耦 Vercel：不设置 TURSO_* 与 BLOB_*，改用本地 SQLite + 本地磁盘

# ── 数据库：本地 SQLite 文件 ──
# 容器内路径，对应 volume 挂载的 /app/data
DATABASE_URL=file:./data/db/lifeos.db

# ── 存储：本地磁盘（替代 Vercel Blob）──
STORAGE_DRIVER=local
UPLOAD_DIR=/app/data/uploads
UPLOAD_URL_PREFIX=/uploads

# ── 登录密码（留空则跳过认证）──
APP_PASSWORD=demo

# ── 可选：Turso 远程库（如需切回 Vercel 式远程库，填这里并设 STORAGE_DRIVER=vercel）──
# TURSO_DATABASE_URL=
# TURSO_AUTH_TOKEN=
# BLOB_READ_WRITE_TOKEN=
