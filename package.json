{
  "name": "opencode-demo",
  "version": "0.2.1",
  "private": true,
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsx scripts/migrate.ts && next dev -H 0.0.0.0 --webpack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "migrate": "tsx scripts/migrate.ts",
    "migrate:dry": "tsx scripts/migrate.ts --dry-run",
    "test": "vitest run",
    "test:watch": "vitest",
    "pretest:e2e": "rm -f .e2e-test.db",
    "test:e2e": "LD_LIBRARY_PATH=\"$PWD/.pw-libs/lib${LD_LIBRARY_PATH:+:$LD_LIBRARY_PATH}\" playwright test && rm -f .e2e-test.db",
    "analyze": "ANALYZE=true next build"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@libsql/client": "^0.17.4",
    "@tanstack/react-virtual": "^3.14.3",
    "@vercel/blob": "^2.6.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "lucide-react": "^1.21.0",
    "next": "16.2.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "rehype-sanitize": "^6.0.0",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^16.2.9",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4",
    "tsx": "^4.23.1",
    "typescript": "^5",
    "vitest": "^4.1.9"
  }
}
